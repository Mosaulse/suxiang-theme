    "tokenColors": [
        {
            "name": "Default foreground",
            "scope": [
                "source"
            ],
            "settings": {
                "foreground": "#423729"
            }
        },
        {
            "name": "Comment",
            "scope": [
                "comment",
                "punctuation.definition.comment"
            ],
            "settings": {
                "foreground": "#A29583",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Keyword",
            "scope": [
                "keyword",
                "storage.type",
                "storage.modifier"
            ],
            "settings": {
                "foreground": "#C54131",
                "fontStyle": "bold"
            }
        },
        {
            "name": "String",
            "scope": [
                "string",
                "punctuation.definition.string"
            ],
            "settings": {
                "foreground": "#D96C4A",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Number & Constant",
            "scope": [
                "constant.numeric",
                "constant.language",
                "support.constant"
            ],
            "settings": {
                "foreground": "#C54131"
            }
        },
        {
            "name": "Function name",
            "scope": [
                "entity.name.function",
                "support.function"
            ],
            "settings": {
                "foreground": "#2E5F88"
            }
        },
        {
            "name": "Type & Class name",
            "scope": [
                "entity.name.type",
                "entity.name.class",
                "entity.name.tag",
                "support.type",
                "support.class"
            ],
            "settings": {
                "foreground": "#2E5F88",
                "fontStyle": "bold"
            }
        },
        {
            "name": "Variable & Parameter",
            "scope": [
                "variable",
                "variable.parameter",
                "variable.other"
            ],
            "settings": {
                "foreground": "#423729"
            }
        },
        {
            "name": "Punctuation & Braces",
            "scope": [
                "punctuation",
                "meta.brace",
                "punctuation.definition"
            ],
            "settings": {
                "foreground": "#7A6D5E"
            }
        },
        {
            "name": "HTML/XML Tag",
            "scope": [
                "entity.name.tag"
            ],
            "settings": {
                "foreground": "#2E5F88"
            }
        },
        {
            "name": "HTML/XML Attribute",
            "scope": [
                "entity.other.attribute-name"
            ],
            "settings": {
                "foreground": "#C54131"
            }
        },
        {
            "name": "Markup Italic",
            "scope": "markup.italic",
            "settings": {
                "fontStyle": "italic"
            }
        },
        {
            "name": "Markup Bold",
            "scope": "markup.bold",
            "settings": {
                "fontStyle": "bold"
            }
        },
        {
            "name": "Invalid",
            "scope": "invalid",
            "settings": {
                "foreground": "#C54131",
                "fontStyle": "underline"
            }
        }
    ]
}