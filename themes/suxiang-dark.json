    "tokenColors": [
        {
            "name": "Default foreground",
            "scope": [
                "source"
            ],
            "settings": {
                "foreground": "#D0C3AE"
            }
        },
        {
            "name": "Comment",
            "scope": [
                "comment",
                "punctuation.definition.comment"
            ],
            "settings": {
                "foreground": "#938A7A"
            }
        },
        {
            "name": "Keyword",
            "scope": [
                "keyword",
                "storage.type",
                "storage.modifier"
            ],
            "settings": {
                "foreground": "#D95B4A"
            }
        },
        {
            "name": "String",
            "scope": [
                "string",
                "punctuation.definition.string"
            ],
            "settings": {
                "foreground": "#E3947C"
            }
        },
        {
            "name": "Number & Constant",
            "scope": [
                "constant.numeric",
                "constant.language",
                "support.constant"
            ],
            "settings": {
                "foreground": "#D95B4A"
            }
        },
        {
            "name": "Function name",
            "scope": [
                "entity.name.function",
                "support.function"
            ],
            "settings": {
                "foreground": "#6FA6C9"
            }
        },
        {
            "name": "Type & Class name",
            "scope": [
                "entity.name.type",
                "entity.name.class",
                "entity.name.tag",
                "support.type",
                "support.class"
            ],
            "settings": {
                "foreground": "#6FA6C9"
            }
        },
        {
            "name": "Variable & Parameter",
            "scope": [
                "variable",
                "variable.parameter",
                "variable.other"
            ],
            "settings": {
                "foreground": "#D0C3AE"
            }
        },
        {
            "name": "Punctuation & Braces",
            "scope": [
                "punctuation",
                "meta.brace",
                "punctuation.definition"
            ],
            "settings": {
                "foreground": "#938A7A"
            }
        },
        {
            "name": "HTML/XML Tag",
            "scope": [
                "entity.name.tag"
            ],
            "settings": {
                "foreground": "#6FA6C9"
            }
        },
        {
            "name": "HTML/XML Attribute",
            "scope": [
                "entity.other.attribute-name"
            ],
            "settings": {
                "foreground": "#D95B4A"
            }
        },
        {
            "name": "Object property & member",
            "scope": [
                "variable.other.property",
                "variable.other.object.property",
                "variable.other.member",
                "meta.object-literal.key",
                "support.variable.property"
            ],
            "settings": {
                "foreground": "#D9A85F"
            }
        },
        {
            "name": "Parameter",
            "scope": [
                "variable.parameter",
                "meta.function.parameters"
            ],
            "settings": {
                "foreground": "#C5B79F"
            }
        },
        {
            "name": "Module & namespace",
            "scope": [
                "entity.name.namespace",
                "entity.name.module",
                "support.module"
            ],
            "settings": {
                "foreground": "#6FA6C9"
            }
        },
        {
            "name": "Decorator & annotation",
            "scope": [
                "meta.decorator",
                "entity.name.function.decorator",
                "punctuation.decorator"
            ],
            "settings": {
                "foreground": "#E3947C"
            }
        },
        {
            "name": "Regular expression",
            "scope": [
                "string.regexp",
                "constant.character.escape"
            ],
            "settings": {
                "foreground": "#E3947C"
            }
        },
        {
            "name": "JSON key",
            "scope": [
                "support.type.property-name.json",
                "meta.structure.dictionary.json string.quoted.double.json"
            ],
            "settings": {
                "foreground": "#6FA6C9"
            }
        },
        {
            "name": "CSS selector & property",
            "scope": [
                "entity.other.attribute-name.class.css",
                "entity.other.attribute-name.id.css",
                "support.type.property-name.css"
            ],
            "settings": {
                "foreground": "#8DC5DE"
            }
        },
        {
            "name": "Markdown heading",
            "scope": [
                "markup.heading",
                "punctuation.definition.heading"
            ],
            "settings": {
                "foreground": "#E3947C"
            }
        },
        {
            "name": "Markdown link & inline code",
            "scope": [
                "markup.inline.raw",
                "markup.underline.link",
                "string.other.link"
            ],
            "settings": {
                "foreground": "#6FA6C9"
            }
        },
        {
            "name": "Invalid",
            "scope": "invalid",
            "settings": {
                "foreground": "#D95B4A"
            }
        }
    ],
    "semanticTokenColors": {
        "namespace": "#6FA6C9",
        "type": {
            "foreground": "#6FA6C9"
        },
        "class": {
            "foreground": "#6FA6C9"
        },
        "interface": {
            "foreground": "#6FA6C9"
        },
        "enum": "#6FA6C9",
        "typeParameter": "#6FA6C9",
        "function": "#6FA6C9",
        "method": "#6FA6C9",
        "macro": "#E3947C",
        "variable": "#D0C3AE",
        "parameter": "#C5B79F",
        "property": "#D9A85F",
        "enumMember": "#D95B4A",
        "event": "#E3947C",
        "decorator": "#E3947C",
        "label": "#938A7A",
        "keyword": {
            "foreground": "#D95B4A"
        },
        "string": "#E3947C",
        "number": "#D95B4A",
        "regexp": "#E3947C",
        "operator": "#938A7A",
        "comment": {
            "foreground": "#938A7A"
        },
        "*.deprecated": {
            "foreground": "#938A7A"
        }
    }
}