  "tokenColors": [
    {
      "name": "Default foreground",
      "scope": ["source"],
      "settings": {
        "foreground": "#D0C3AE"
      }
    },
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#938A7A",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#D95B4A",
        "fontStyle": "bold"
      }
    },
    {
      "name": "String",
      "scope": ["string", "punctuation.definition.string"],
      "settings": {
        "foreground": "#E3947C",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Number & Constant",
      "scope": ["constant.numeric", "constant.language", "support.constant"],
      "settings": {
        "foreground": "#D95B4A"
      }
    },
    {
      "name": "Function name",
      "scope": ["entity.name.function", "support.function"],
      "settings": {
        "foreground": "#6FA6C9"
      }
    },
    {
      "name": "Type & Class name",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.tag",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#6FA6C9",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Variable & Parameter",
      "scope": [
        "variable",
        "variable.parameter",
        "variable.other"
      ],
      "settings": {
        "foreground": "#D0C3AE"
      }
    },
    {
      "name": "Punctuation & Braces",
      "scope": ["punctuation", "meta.brace", "punctuation.definition"],
      "settings": {
        "foreground": "#938A7A"
      }
    },
    {
      "name": "HTML/XML Tag",
      "scope": ["entity.name.tag"],
      "settings": {
        "foreground": "#6FA6C9"
      }
    },
    {
      "name": "HTML/XML Attribute",
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#D95B4A"
      }
    },
    {
      "name": "Markup Italic",
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markup Bold",
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "name": "Invalid",
      "scope": "invalid",
      "settings": {
        "foreground": "#D95B4A",
        "fontStyle": "underline"
      }
    }
  ]
}